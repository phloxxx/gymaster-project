<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv="X-UA-Compatible" content="ie-edge,safari">
        <link href='https://fonts.googleapis.com/css?family=Raleway' rel='stylesheet'>
        <link rel="stylesheet" href="/navbar.css">
        <link rel="stylesheet" href="/addmember.css">
        <title>{{ title }}</title>
    </head>
    <header>
        <div class="logo">
            <img class="img" src="/images/gymaster.png" alt="GYMASTER Logo"> 
        </div>
        <nav class="navbar">
            <a href="/member" style="color: #042031;">Member</a>
            <a href="/coach">Coach</a>
            <a href="/program">Program</a>
            <a href="/subscription">Subscription</a>
            <a href="/payment">Payment</a>
            <a href="/settings">Settings</a>    
        </nav>
    </header>
    <body>
        <div class="container">
            <div class="form-container  contain">
                <form action="/register/submit" method="POST">
                    <form action="/register/submit" method="POST">
                        <h1>ADD MEMBER</h1>
                        <input type="text" id="fname" name="firstame" placeholder="Firstname" required><br>
                        <input type="text" id="lname" name="lastame" placeholder="Lastname" required><br>
                        <input type="email" id="email" name="email" placeholder="Email" required><br>  
                        <input type="text" id="phonenumber" name="phonenumber" placeholder="Phone Number" required><br>
                        <input type="text" id="program" name="program" placeholder="Program" required><br>  
                        <input type="text" id="coach" name="coach" placeholder="Coach" required><br>                  
                    </form>
                    <form action="/register" method="POST">
                        <h1>MEMBER SUBSCRIPTION</h1>
                        <input type="text" id="subscription" name="subscription" placeholder="Subscription" required><br>
                    </form>
                    <div class="contain">
                            <button type="submit">Save</button>
                            <button type="button">Cancel</button>
                    </div>
                <form action="/register/submit" method="POST">
            </div>
        </div>
    </body>
</html>
